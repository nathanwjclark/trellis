# Required for cycle phases (extrapolate, index, dedupe, dream)
ANTHROPIC_API_KEY=

# Optional: only needed if you set TRELLIS_MODEL_EMBEDDING to a "voyage-*"
# model. By default Trellis embeds locally via transformers.js (no key).
VOYAGE_API_KEY=

# Agent identity (PR #10). Default: trellis-default. Each identity gets its
# own persistent workspace (data/agents/<identity>/workspace/) and openclaw
# state dir, so memory + skills accumulate across leaves.
# TRELLIS_AGENT_IDENTITY=trellis-default

# OpenClaw setup mode (PR #10/#12).
#   test (default) — Trellis owns the workspace + state dir, pre-fills
#     SOUL.md/IDENTITY.md/AGENTS.md, writes openclaw.json with memory +
#     skill plugins enabled and skipBootstrap=true.
#   prod — Trellis is a CLIENT of your existing openclaw setup. Doesn't
#     touch your openclaw.json, expects SOUL.md to already exist (run
#     `openclaw onboard` first if not). Override the paths below to point
#     at your real openclaw layout.
# TRELLIS_OPENCLAW_MODE=test

# Prod-mode path overrides (PR #12). Point at your existing openclaw setup.
# Trellis writes its transient brief files into <workspace>/.trellis/ so
# the workspace root stays clean.
# TRELLIS_AGENT_WORKSPACE=/Users/you/openclaw-workspace
# TRELLIS_AGENT_STATE_DIR=/Users/you/.openclaw

# v0.5: web research
BRAVE_API_KEY=
TAVILY_API_KEY=

# v0.2+: path to the openclaw checkout for subprocess execution
OPENCLAW_PATH=/Users/nathanclark/claude-projects/openclaw

# Optional: override defaults
TRELLIS_DB_PATH=./data/trellis.db
TRELLIS_PORT=18810
TRELLIS_DAILY_USD_BUDGET=10
