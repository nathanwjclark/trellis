# Required for cycle phases (extrapolate, index, dedupe, dream)
ANTHROPIC_API_KEY=

# Optional: only needed if you set TRELLIS_MODEL_EMBEDDING to a "voyage-*"
# model. By default Trellis embeds locally via transformers.js (no key).
VOYAGE_API_KEY=

# Agent identity (PR #10). Default: trellis-default. Each identity gets its
# own persistent workspace (data/agents/<identity>/workspace/) and openclaw
# state dir, so memory + skills accumulate across leaves.
# TRELLIS_AGENT_IDENTITY=trellis-default

# OpenClaw setup mode. Default: test (pre-fills SOUL.md/IDENTITY.md/AGENTS.md
# and skips openclaw onboarding). prod expects you to have run
# `openclaw onboard` against the agent's state dir first.
# TRELLIS_OPENCLAW_MODE=test

# v0.5: web research
BRAVE_API_KEY=
TAVILY_API_KEY=

# v0.2+: path to the openclaw checkout for subprocess execution
OPENCLAW_PATH=/Users/nathanclark/claude-projects/openclaw

# Optional: override defaults
TRELLIS_DB_PATH=./data/trellis.db
TRELLIS_PORT=18810
TRELLIS_DAILY_USD_BUDGET=10
