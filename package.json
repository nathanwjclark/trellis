{
  "name": "trellis",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Graph-native task architecture for OpenClaw agents",
  "engines": {
    "node": ">=22.16"
  },
  "bin": {
    "trellis": "./dist/cli/trellis.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "trellis": "tsx src/cli/trellis.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:live": "TRELLIS_LIVE=1 vitest run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.40.0",
    "@hono/node-server": "^2.0.1",
    "@huggingface/transformers": "^4.2.0",
    "better-sqlite3": "^11.5.0",
    "hono": "^4.12.18",
    "uuid": "^11.0.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.11",
    "@types/node": "^22.9.0",
    "@types/uuid": "^10.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3",
      "esbuild",
      "onnxruntime-node",
      "protobufjs",
      "sharp"
    ]
  }
}
